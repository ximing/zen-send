# Server
PORT=3001
NODE_ENV=development
CORS_ORIGIN=*

# Database (MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=zen_send

# JWT (required in production)
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production

# S3 (for file transfers)
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET=zen-send-transfers
TRANSFER_TTL_DAYS=30
