{
  "name": "@zen-send/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=development nodemon --exec node --loader ts-node/esm ./src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "clean": "rm -rf dist",
    "migrate:generate": "drizzle-kit generate",
    "migrate:migrate": "drizzle-kit migrate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1024.0",
    "@aws-sdk/s3-request-presigner": "^3.1024.0",
    "@zen-send/dto": "workspace:*",
    "@zen-send/logger": "workspace:*",
    "@zen-send/shared": "workspace:*",
    "bcryptjs": "^2.4.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.0",
    "drizzle-orm": "^0.45.2",
    "express": "^4.21.0",
    "glob": "^11.1.0",
    "jsonwebtoken": "^9.0.3",
    "mysql2": "^3.20.0",
    "nanoid": "^5.1.7",
    "reflect-metadata": "^0.2.2",
    "routing-controllers": "^0.11.3",
    "socket.io": "^4.8.3",
    "typedi": "^0.10.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/glob": "^8.1.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.0.0",
    "@zen-send/eslint-config": "workspace:*",
    "@zen-send/typescript-config": "workspace:*",
    "drizzle-kit": "^0.31.10",
    "nodemon": "^2.0.20",
    "cross-env": "^10.1.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.7.3"
  }
}
