{
  "name": "zen-send",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@10.22.0",
  "scripts": {
    "dev": "pnpm -r dev",
    "dev:web": "pnpm --filter @zen-send/web dev",
    "dev:server": "pnpm --filter @zen-send/server dev",
    "dev:mobile": "pnpm --filter @zen-send/mobile start",
    "build": "pnpm -r build",
    "build:web": "pnpm --filter @zen-send/web build",
    "build:server": "pnpm --filter @zen-send/server build",
    "build:mobile": "pnpm --filter @zen-send/mobile build",
    "lint": "turbo lint",
    "lint:fix": "turbo lint:fix",
    "format": "prettier --write .",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "rm": "find . -name \"node_modules\" -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "@changesets/cli": "^2.28.0",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.4",
    "@types/node": "^20.0.0",
    "eslint": "^9.19.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.0",
    "husky": "^9.1.7",
    "prettier": "^3.5.1",
    "turbo": "^2.4.2",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.58.0"
  },
  "pnpm": {
    "overrides": {
      "react": "19.2.3",
      "react-native-renderer": "19.2.3",
      "react-dom": "19.2.3"
    }
  }
}
